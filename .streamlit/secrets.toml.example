APP_PASSWORD = "password"
ORGANIZATION = "Company Name"
AUDIENCE = "customers and users"
ANTHROPIC_API_KEY = "sk-..."
OPENAI_API_KEY = "sk-..."

# Optional: email completed audit workbooks to the user. Omit these to disable
# the "Email results to me" option. Example values shown are for SendGrid; for
# Gmail use smtp.gmail.com with an App Password as SMTP_PASSWORD.
SMTP_HOST = "smtp.sendgrid.net"
SMTP_PORT = 587
SMTP_USER = "apikey"            # SendGrid: literally the word "apikey"
SMTP_PASSWORD = "SG.xxxxx..."   # SendGrid API key (Mail Send permission)
EMAIL_FROM = "audit-noreply@yourcompany.com"  # a verified sender address
